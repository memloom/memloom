{
  "name": "@memloom/server",
  "version": "0.1.0",
  "type": "module",
  "description": "memloom local HTTP server (Hono): wraps core, owns the single PGLite connection.",
  "license": "Apache-2.0",
  "author": "Kostek Sytnyk <kostek@versuno.ai>",
  "homepage": "https://memloom.dev",
  "keywords": [
    "memory",
    "ai",
    "agents",
    "local-first",
    "context",
    "mcp",
    "knowledge-graph"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/memloom/memloom.git",
    "directory": "packages/server"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@memloom/core": "workspace:*",
    "hono": "^4.6.0",
    "zod": "^3.25.76"
  }
}
