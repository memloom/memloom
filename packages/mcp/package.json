{
  "name": "@memloom/mcp",
  "version": "0.1.1",
  "type": "module",
  "description": "memloom MCP server (stdio): save_memory, recall_memory, resolve_conflict.",
  "license": "Apache-2.0",
  "author": "Kostek Sytnyk <kostek@versuno.ai>",
  "homepage": "https://memloom.dev",
  "keywords": [
    "memory",
    "ai",
    "agents",
    "local-first",
    "context",
    "mcp",
    "knowledge-graph"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/memloom/memloom.git",
    "directory": "packages/mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "memloom-mcp": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@memloom/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "memloom": "workspace:*",
    "zod": "^3.24.0"
  }
}
