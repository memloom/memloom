{
  "name": "memloom",
  "version": "0.1.0",
  "type": "module",
  "description": "A memory engine for AI agents that you can see and correct: one Postgres store shared by CLI, MCP, HTTP, and a viewer.",
  "license": "Apache-2.0",
  "author": "Kostek Sytnyk <kostek@versuno.ai>",
  "homepage": "https://memloom.dev",
  "keywords": [
    "memory",
    "ai",
    "agents",
    "local-first",
    "context",
    "mcp",
    "knowledge-graph"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/memloom/memloom.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "memloom": "./dist/bin.js"
  },
  "files": [
    "dist",
    "viewer"
  ],
  "scripts": {
    "build": "tsup && node scripts/embed-viewer.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@electric-sql/pglite-socket": "^0.0.14",
    "@hono/node-server": "^1.13.0",
    "@memloom/core": "workspace:*",
    "@memloom/server": "workspace:*"
  },
  "devDependencies": {
    "@memloom/viewer": "workspace:*"
  }
}
