{
  "name": "memloom",
  "version": "0.0.0",
  "type": "module",
  "description": "memloom CLI: init, save, recall, index, conflicts, serve, ui.",
  "license": "Apache-2.0",
  "author": "Kostek Sytnyk <kostek@versuno.ai>",
  "homepage": "https://memloom.dev",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "memloom": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@electric-sql/pglite-socket": "^0.0.14",
    "@memloom/core": "workspace:*",
    "@memloom/server": "workspace:*"
  }
}
