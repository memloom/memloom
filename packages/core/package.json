{
  "name": "@memloom/core",
  "version": "0.1.1",
  "type": "module",
  "description": "The memloom memory engine: storage adapter, providers, write path, retrieval.",
  "license": "Apache-2.0",
  "author": "Kostek Sytnyk <kostek@versuno.ai>",
  "homepage": "https://memloom.dev",
  "keywords": [
    "memory",
    "ai",
    "agents",
    "local-first",
    "context",
    "mcp",
    "knowledge-graph"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/memloom/memloom.git",
    "directory": "packages/core"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "proper-lockfile": "^4.1.2",
    "unpdf": "^1.6.2"
  },
  "optionalDependencies": {
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "@types/proper-lockfile": "^4.1.4"
  }
}
