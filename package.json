    "test": "vitest run",
    "release": "pnpm -r publish --access public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/node": "^22.10.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
