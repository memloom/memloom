{
  "name": "memloom-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "memloom: a memory engine for AI agents. Monorepo root.",
  "license": "Apache-2.0",
  "author": "Kostek Sytnyk <kostek@versuno.ai>",
  "homepage": "https://memloom.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/memloom/memloom.git"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "pnpm -r --if-present build",
