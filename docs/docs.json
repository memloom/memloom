{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "memloom",
  "colors": {
    "primary": "#d97706",
    "light": "#f59e0b",
    "dark": "#b45309"
  },
  "api": {
    "playground": {
      "display": "simple"
    },
    "params": {
      "expanded": "all"
    },
    "examples": {
      "languages": ["curl", "python", "javascript", "go", "php", "ruby", "java", "csharp"],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "features", "use-cases"]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/architecture",
              "concepts/memory-types",
              "concepts/conflicts",
              "concepts/graph",
              "concepts/retrieval",
              "concepts/assistant"
            ]
          },
          {
            "group": "Guides",
            "pages": ["guides/extractors", "guides/configuration", "guides/self-hosting"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Memory",
            "openapi": "openapi.yaml",
            "pages": [
              "POST /memory/save",
              "POST /memory/query",
              "POST /memory/index",
              "POST /memory/reindex",
              "GET /memory/graph"
            ]
          },
          {
            "group": "Schema & entities",
            "openapi": "openapi.yaml",
            "pages": [
              "GET /memory/schema",
              "POST /memory/schema",
              "PATCH /memory/schema/{id}",
              "DELETE /memory/schema/{id}",
              "POST /memory/schema/{id}/approve",
              "POST /memory/schema/{id}/dismiss",
              "GET /memory/entities",
              "PATCH /memory/entities/{id}",
              "POST /memory/entities/{id}/merge",
              "DELETE /memory/entities/{id}"
            ]
          },
          {
            "group": "Assistant",
            "openapi": "openapi.yaml",
            "pages": [
              "POST /assistant/chat",
              "GET /assistant/models",
              "GET /assistant/sessions",
              "GET /assistant/sessions/search",
              "GET /assistant/sessions/{id}/messages",
              "PATCH /assistant/sessions/{id}",
              "DELETE /assistant/sessions/{id}",
              "POST /assistant/attachments",
              "GET /assistant/sessions/{id}/attachments"
            ]
          },
          {
            "group": "Context",
            "openapi": "openapi.yaml",
            "pages": [
              "POST /context/add",
              "POST /context/upload",
              "GET /context/documents",
              "DELETE /context/documents/{id}"
            ]
          },
          {
            "group": "Conflicts",
            "openapi": "openapi.yaml",
            "pages": [
              "GET /memory/conflicts",
              "POST /memory/conflicts/{id}/resolve",
              "POST /memory/conflicts/{id}/revert"
            ]
          },
          {
            "group": "Daemon",
            "openapi": "openapi.yaml",
            "pages": ["GET /health", "POST /admin/shutdown"]
          }
        ]
      },
      {
        "tab": "CLI Reference",
        "groups": [
          {
            "group": "CLI",
            "pages": ["cli/overview"]
          },
          {
            "group": "Commands",
            "pages": [
              "cli/daemon",
              "cli/memories",
              "cli/graph",
              "cli/context",
              "cli/conflicts"
            ]
          }
        ]
      },
      {
        "tab": "MCP Reference",
        "groups": [
          {
            "group": "MCP",
            "pages": ["mcp/setup", "mcp/tools"]
          },
          {
            "group": "Clients",
            "pages": [
              "mcp/clients/claude-code",
              "mcp/clients/claude-desktop",
              "mcp/clients/cursor",
              "mcp/clients/vs-code",
              "mcp/clients/windsurf",
              "mcp/clients/cline",
              "mcp/clients/zed",
              "mcp/clients/codex",
              "mcp/clients/opencode"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://memloom.dev"
      }
    ]
  }
}
